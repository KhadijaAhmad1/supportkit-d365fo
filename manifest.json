{
  "manifest_version": 3,
  "name": "SupportKit for D365 F&O",
  "version": "1.0.0",
  "description": "The support engineer's toolkit for Dynamics 365 Finance & Operations. One-click ticket context capture, environment guardian, table browser and OData shortcuts.",
  "author": "Khadija",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["storage", "activeTab"],
  "host_permissions": ["https://*.dynamics.com/*"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "SupportKit for D365 F&O"
  },
  "options_page": "options.html",
  "content_scripts": [
    {
      "matches": ["https://*.dynamics.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
